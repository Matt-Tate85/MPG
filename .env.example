# DVLA Vehicle Enquiry Service API Key
# Free from https://developer-portal.driver-vehicle-licensing.agency.gov.uk/
DVLA_API_KEY=your_key_here

# Open Charge Map API Key (optional but recommended for higher rate limits)
# Free from https://openchargemap.org/site/develop/api
OCM_API_KEY=your_key_here

# CMA Fuel Finder API (optional - UK government open data)
# Register at: https://www.gov.uk/government/collections/road-fuel-price-data-scheme
# Provides higher rate limits when authenticated
CMA_API_KEY=

# Optional: legacy OPIS key (superseded by CMA scheme Feb 2026)
OPIS_API_KEY=

NEXT_PUBLIC_APP_URL=http://localhost:3000
